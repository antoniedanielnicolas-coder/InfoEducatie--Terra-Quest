{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "run server",
            "type": "shell",
            "command": "node",
            "args": [
                "infoeducatieee/server.js"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "GeoInformatica server running at"
                }
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        }
    ]
}
